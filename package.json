{
	"name": "duolife",
	"private": true,
	"packageManager": "bun@1.3.3",
	"type": "module",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^5",
			"convex": "^1.32.0",
			"better-auth": "1.4.9",
			"@better-auth/expo": "1.4.9",
			"@convex-dev/better-auth": "^0.10.11"
		}
	},
	"scripts": {
		"check": "biome check --write .",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F @app/backend dev",
		"dev:setup": "turbo -F @app/backend dev:setup"
	},
	"dependencies": {
		"@app/env": "workspace:*",
		"dotenv": "^17.4.2",
		"expo-clipboard": "~55.0.13",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@app/config": "workspace:*",
		"@biomejs/biome": "^2.4.12",
		"turbo": "^2.9.6",
		"typescript": "^5.9.3"
	}
}
